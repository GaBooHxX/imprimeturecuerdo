rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isOwner() {
      return signedIn() &&
        request.auth.token.email in [
          'gabooh1516@gmail.com',
          'gabriel.amadorf@gmail.com'
        ];
    }
    function isGlobalAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isMemorialAdmin(mid) {
      return signedIn() &&
        exists(/databases/$(database)/documents/memorials/$(mid)/admin/$(request.auth.uid));
    }
    function isMod(mid) {
      return signedIn() &&
        exists(/databases/$(database)/documents/memorials/$(mid)/mods/$(request.auth.uid));
    }
    // Editor: email del usuario está en la lista editorEmails del memorial
    function isEditor(mid) {
      return signedIn() &&
        request.auth.token.email != null &&
        get(/databases/$(database)/documents/memorials/$(mid)/meta/settings)
          .data.get('editorEmails', [])
          .hasAny([request.auth.token.email.lower()]);
    }
    function canManage(mid) { return isOwner() || isGlobalAdmin() || isMemorialAdmin(mid); }
    function canEdit(mid)   { return canManage(mid) || isEditor(mid); }
    function canModerate(mid) { return canManage(mid) || isMod(mid); }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /memorials/{mid} {
      allow read: if true;

      match /admin/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || canManage(mid));
        allow write: if isOwner() || isGlobalAdmin();
      }

      match /mods/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || canModerate(mid));
        allow write: if canManage(mid);
      }

      // Configuración del memorial (displayName, isActive, editorEmails)
      // Cualquier usuario firmado puede leer (necesario para que el editor verifique su acceso)
      // Solo owners/admins pueden escribir
      match /meta/settings {
        allow read: if signedIn();
        allow write: if canManage(mid);
      }

      // Contenido editable: owners/admins/editores pueden escribir
      match /meta/content {
        allow read: if true;
        allow write: if canEdit(mid);
      }

      // Galería: owners/admins/editores pueden escribir
      match /gallery/{photoKey} {
        allow read: if true;
        allow write: if canEdit(mid);
      }

      match /meta/stats {
        allow read: if true;
        allow write: if true;
      }

      match /candles/{uid} {
        allow read: if true;
        allow create, update, delete: if signedIn() && request.auth.uid == uid;
      }

      match /photos/{pid}/comments/{cid} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if canModerate(mid) ||
                         (signedIn() && resource.data.uid == request.auth.uid);
        allow delete: if canModerate(mid);
      }

      match /photos/{pid}/reactions/{uid} {
        allow read: if true;
        allow write: if signedIn() && request.auth.uid == uid;
      }

      match /guestbook/{gid} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if canModerate(mid) ||
                         (signedIn() && resource.data.uid == request.auth.uid);
        allow delete: if canModerate(mid);
      }
    }
  }
}
